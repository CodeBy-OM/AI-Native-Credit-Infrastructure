{
  "info": {
    "_postman_id": "vitto-api-collection",
    "name": "Vitto API",
    "description": "Complete API collection for Vitto — AI-Native Credit Infrastructure\n\n## Setup\n1. Set `base_url` variable to `http://localhost:4000` (or your deployed URL)\n2. Run `Send OTP` first, then `Verify OTP` — copy the `token` from the response\n3. Set `auth_token` variable to that token\n4. Run `Create Lead` and `Get Lead`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4000", "type": "string" },
    { "key": "auth_token", "value": "", "type": "string" },
    { "key": "lead_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "1. Send OTP",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.otp) {",
                "  pm.collectionVariables.set('test_otp', res.otp);",
                "  console.log('OTP saved:', res.otp);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/send-otp", "host": ["{{base_url}}"], "path": ["api","auth","send-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cto@aavas.in\"\n}"
            }
          }
        },
        {
          "name": "1b. Send OTP (Phone)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/send-otp", "host": ["{{base_url}}"], "path": ["api","auth","send-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+919876543210\"\n}"
            }
          }
        },
        {
          "name": "2. Verify OTP",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.token) {",
                "  pm.collectionVariables.set('auth_token', res.token);",
                "  console.log('Token saved');",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/verify-otp", "host": ["{{base_url}}"], "path": ["api","auth","verify-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cto@aavas.in\",\n  \"otp\": \"{{test_otp}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Leads",
      "item": [
        {
          "name": "3. Create Lead",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.id) {",
                "  pm.collectionVariables.set('lead_id', res.id);",
                "  console.log('Lead ID saved:', res.id);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/leads", "host": ["{{base_url}}"], "path": ["api","leads"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cto@aavas.in\",\n  \"phone\": \"+919876543210\",\n  \"institution_name\": \"Aavas Financiers\",\n  \"institution_type\": \"Housing Finance Company\",\n  \"city\": \"Jaipur\",\n  \"loan_book_size\": \"₹1,000–5,000 Cr\"\n}"
            }
          }
        },
        {
          "name": "4. Get Lead by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/leads/{{lead_id}}", "host": ["{{base_url}}"], "path": ["api","leads","{{lead_id}}"] }
          }
        },
        {
          "name": "List All Leads",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/leads", "host": ["{{base_url}}"], "path": ["api","leads"] }
          }
        }
      ]
    },
    {
      "name": "Contact",
      "item": [
        {
          "name": "Submit Demo Request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/contact", "host": ["{{base_url}}"], "path": ["api","contact"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rajesh Menon\",\n  \"email\": \"rajesh@aavas.in\",\n  \"phone\": \"+919876543210\",\n  \"institution\": \"Aavas Financiers\",\n  \"role\": \"CRO / Head of Credit\",\n  \"message\": \"We want to evaluate Vitto for MSME underwriting automation.\"\n}"
            }
          }
        }
      ]
    }
  ]
}
